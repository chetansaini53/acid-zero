# Acid Zero - Pico 2 W BadUSB (AP MODE) - OPTIONAL.
#
# The Pico hosts its OWN WiFi access point, so it needs NO external WiFi and this
# file is OPTIONAL. Copy it to the CIRCUITPY drive as `settings.toml` ONLY if you
# want to change the default AP name / password.
#
# Defaults (baked into code.py): SSID "AcidZero-Duck", password "acidzero1337".
# EASIEST: set the SSID/password in the on-device Flasher (or the Bad USB app's
# "AP creds" screen) - it writes this file for you AND shares the creds so CONNECT
# joins the right AP automatically. Only edit this file by hand if you flash the
# Pico from a laptop; then set the same values in the Bad USB app's AP creds.
#
# Do NOT set CIRCUITPY_WIFI_SSID/PASSWORD here - that makes CircuitPython auto-join
# a station network at boot, which fights AP mode.

ACIDZERO_AP_SSID = "AcidZero-Duck"
ACIDZERO_AP_PASSWORD = "acidzero1337"   # WPA2: must be at least 8 characters
